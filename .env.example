# ============================================================
#  LIVING WORLDS — Environment Variables
#  Copy this file to `.env.local` for local dev, and set the
#  same vars in your Vercel Project Settings → Environment Variables.
#  NEVER commit real keys. These stay server-side only and are
#  read exclusively inside app/api/ai/route.ts.
# ============================================================

# --- AI provider for the in-world narrative engine ---
# Which provider the /api/ai route should use: "anthropic" | "openai"
AI_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# --- Commerce ---
# Public SamCart checkout URL for the Entertainment Pass CTA.
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_CHECKOUT_URL=https://legacystudiooriginals.com/livingworlds-pass
